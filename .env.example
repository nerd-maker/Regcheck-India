# LLM Configuration (NVIDIA OpenAI-compatible)
LLM_API_KEY=your_nvidia_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=openai/gpt-oss-120b
SARVAM_API_KEY=your_sarvam_api_key_here
BHARATGEN_API_KEY=your_bharatgen_api_key_here
BHARATGEN_API_BASE=https://api.bharatgen.ai/v1
HF_API_KEY=your_hf_api_key_here
AUDIT_LOG_ENCRYPTION_KEY=your_fernet_key_here
AUDIT_LOG_RETENTION_DAYS=30
REGCHECK_RUNTIME_STATE_DB=./data/runtime/runtime_state.db

# ChromaDB
CHROMADB_PATH=/app/data/chromadb

# Server
ENVIRONMENT=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://your-vercel-url.vercel.app

# File Upload
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
