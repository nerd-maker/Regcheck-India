# =============================================================================
# RegCheck-India Environment Configuration
# =============================================================================

# ---- Required ----
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ENVIRONMENT=production

# ---- Model ----
LLM_MODEL=claude-sonnet-4-20250514
LLM_MODEL_FAST=claude-haiku-4-20250414
LLM_MAX_TOKENS=8000
LLM_TEMPERATURE=0.0

# ---- Server ----
BACKEND_PORT=8000
FRONTEND_PORT=3000
ALLOWED_ORIGINS=https://your-vercel-url.vercel.app
LOG_LEVEL=INFO

# ---- ChromaDB ----
CHROMADB_PATH=/app/data/chromadb
CHROMADB_COLLECTION_NAME=regulatory_knowledge
MEMORY_OPTIMIZED_MODE=true

# ---- File Uploads ----
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ---- Audit & Runtime ----
AUDIT_LOG_ENCRYPTION_KEY=your_fernet_key_here
AUDIT_LOG_RETENTION_DAYS=30
REGCHECK_RUNTIME_STATE_DB=./data/runtime/runtime_state.db

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=30

# ---- RAG ----
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.7
